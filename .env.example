# Database
DATABASE_URL=postgresql://user:password@localhost:5432/bossroom

# Server
PORT=8080
LOG_LEVEL=DEBUG
ALLOWED_ORIGIN=*

# Frontend WebSocket URL (local dev only — Terraform manages prod in Cloudflare Pages)
# DO NOT manually set NEXT_PUBLIC_WS_URL in Cloudflare dashboard — `terraform apply` handles it
NEXT_PUBLIC_WS_URL=ws://localhost:8080
NEXT_PUBLIC_SERVER_HTTP_URL=http://localhost:8080
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_VOICE_ENABLED=true

# Firebase Admin (Server)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Cloudflare AI Gateway
CF_AI_GATEWAY_ACCOUNT_ID=
CF_AI_GATEWAY_ID=
CF_AI_GATEWAY_TOKEN=

# Provider API Keys (at least one required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# Vercel AI Gateway
AI_GATEWAY_API_KEY=

# Composio (optional — agent tools won't work without it)
COMPOSIO_API_KEY=

# Deepgram STT (server only — never expose to frontend)
DEEPGRAM_API_KEY=

# Inworld TTS
INWORLD_API_KEY=
INWORLD_VOICE_ID=Dominus
INWORLD_TTS_MODEL_ID=inworld-tts-1.5-mini

# ========================================
# CLOUDFLARE PAGES DEPLOYMENT
# ========================================
#
# All NEXT_PUBLIC_* env vars for Cloudflare Pages are managed by Terraform.
# Run `terraform apply` — it sets NEXT_PUBLIC_WS_URL=wss://... automatically.
# Do NOT manually copy these values into the Cloudflare dashboard.
